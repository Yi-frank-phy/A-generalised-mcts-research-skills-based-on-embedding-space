{
  "$defs": {
    "BudgetSpec": {
      "additionalProperties": false,
      "description": "Hard budget limits for one DTE run.",
      "properties": {
        "max_committed_search_nodes": {
          "default": 20,
          "maximum": 100,
          "minimum": 1,
          "title": "Max Committed Search Nodes",
          "type": "integer"
        },
        "max_iterations": {
          "default": 10,
          "maximum": 20,
          "minimum": 1,
          "title": "Max Iterations",
          "type": "integer"
        },
        "allocation_mass_per_iteration": {
          "default": 3,
          "maximum": 50,
          "minimum": 1,
          "title": "Allocation Mass Per Iteration",
          "type": "integer"
        },
        "max_children_per_iteration": {
          "default": 5,
          "maximum": 50,
          "minimum": 1,
          "title": "Max Children Per Iteration",
          "type": "integer"
        },
        "max_relation_pairs_per_episode": {
          "default": 3,
          "maximum": 20,
          "minimum": 1,
          "title": "Max Relation Pairs Per Episode",
          "type": "integer"
        },
        "max_relation_enrichment_pairs": {
          "default": 3,
          "maximum": 100,
          "minimum": 0,
          "title": "Max Relation Enrichment Pairs",
          "type": "integer"
        },
        "max_research_iterations": {
          "default": 1,
          "maximum": 5,
          "minimum": 0,
          "title": "Max Research Iterations",
          "type": "integer"
        },
        "min_iterations_before_synthesis": {
          "default": 2,
          "maximum": 20,
          "minimum": 1,
          "title": "Min Iterations Before Synthesis",
          "type": "integer"
        },
        "entropy_change_threshold": {
          "default": 0.05,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Entropy Change Threshold",
          "type": "number"
        },
        "entropy_plateau_confirmations": {
          "default": 2,
          "maximum": 10,
          "minimum": 1,
          "title": "Entropy Plateau Confirmations",
          "type": "integer"
        },
        "continuation_policy": {
          "default": "bounded_node_yield_v1",
          "enum": [
            "legacy_entropy_v1",
            "bounded_node_yield_v1"
          ],
          "title": "Continuation Policy",
          "type": "string"
        },
        "t_max": {
          "default": 1.0,
          "exclusiveMinimum": 0.0,
          "maximum": 10.0,
          "title": "T Max",
          "type": "number"
        }
      },
      "title": "BudgetSpec",
      "type": "object"
    },
    "DTERunSpec": {
      "additionalProperties": false,
      "description": "Top-level run specification.\n\nThis is the source of truth. Free-form Markdown or prompt text cannot\noverride this object after validation.",
      "properties": {
        "problem": {
          "minLength": 1,
          "title": "Problem",
          "type": "string"
        },
        "goal": {
          "minLength": 1,
          "title": "Goal",
          "type": "string"
        },
        "constraints": {
          "items": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "array"
        },
        "mode": {
          "const": "mandatory_frontier",
          "default": "mandatory_frontier",
          "title": "Mode",
          "type": "string"
        },
        "budget": {
          "$ref": "#/$defs/BudgetSpec"
        },
        "operator_policy": {
          "$ref": "#/$defs/OperatorPolicy"
        },
        "allow_self_organized_executor": {
          "default": true,
          "title": "Allow Self Organized Executor",
          "type": "boolean"
        },
        "require_final_synthesis": {
          "default": true,
          "title": "Require Final Synthesis",
          "type": "boolean"
        },
        "embedding_provider": {
          "default": "hash",
          "enum": [
            "hash",
            "gemini-embedding-2"
          ],
          "title": "Embedding Provider",
          "type": "string"
        },
        "embedding_dimension": {
          "default": 3072,
          "maximum": 3072,
          "minimum": 8,
          "title": "Embedding Dimension",
          "type": "integer"
        }
      },
      "required": [
        "problem",
        "goal"
      ],
      "title": "DTERunSpec",
      "type": "object"
    },
    "OperatorPolicy": {
      "additionalProperties": false,
      "description": "Narrow delegation policy for privileged controller commands.",
      "properties": {
        "main_agent_may_request_synthesis": {
          "default": true,
          "title": "Main Agent May Request Synthesis",
          "type": "boolean"
        }
      },
      "title": "OperatorPolicy",
      "type": "object"
    },
    "SearchNode": {
      "additionalProperties": false,
      "description": "A node in the DTE search graph/frontier.",
      "properties": {
        "node_id": {
          "title": "Node Id",
          "type": "string"
        },
        "node_type": {
          "default": "candidate",
          "enum": [
            "candidate",
            "evidence",
            "counterexample",
            "merge",
            "synthesis"
          ],
          "title": "Node Type",
          "type": "string"
        },
        "claim": {
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        },
        "assumptions": {
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "evidence": {
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        },
        "risks": {
          "items": {
            "type": "string"
          },
          "title": "Risks",
          "type": "array"
        },
        "parent_ids": {
          "items": {
            "type": "string"
          },
          "title": "Parent Ids",
          "type": "array"
        },
        "confidence": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "local_embedding": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Local Embedding"
        },
        "judge_reasoning": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Judge Reasoning"
        },
        "judge_risks": {
          "items": {
            "type": "string"
          },
          "title": "Judge Risks",
          "type": "array"
        },
        "judge_uncertainty_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Judge Uncertainty Evidence",
          "type": "array"
        },
        "judge_result_provenance": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Judge Result Provenance"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "density": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Density"
        },
        "uncertainty": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uncertainty"
        },
        "ucb_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ucb Score"
        },
        "expansion_budget": {
          "default": 0,
          "minimum": 0,
          "title": "Expansion Budget",
          "type": "integer"
        },
        "status": {
          "default": "frontier",
          "enum": [
            "frontier",
            "closed",
            "archived",
            "merged",
            "synthesis"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "claim"
      ],
      "title": "SearchNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Request passed from DTE Expansion to an external executor adapter.",
  "properties": {
    "parent": {
      "$ref": "#/$defs/SearchNode"
    },
    "child_count": {
      "maximum": 50,
      "minimum": 1,
      "title": "Child Count",
      "type": "integer"
    },
    "iteration": {
      "minimum": 1,
      "title": "Iteration",
      "type": "integer"
    },
    "spec": {
      "anyOf": [
        {
          "$ref": "#/$defs/DTERunSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "parent",
    "child_count",
    "iteration"
  ],
  "title": "ExpansionRequest",
  "type": "object"
}
