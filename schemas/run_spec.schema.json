{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DTERunSpec",
  "type": "object",
  "required": [
    "problem",
    "goal",
    "mode",
    "budget"
  ],
  "properties": {
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "const": "mandatory_frontier"
    },
    "operator_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "main_agent_may_request_synthesis": {
          "type": "boolean",
          "default": true
        }
      },
      "default": {
        "main_agent_may_request_synthesis": true
      }
    },
    "allow_self_organized_executor": {
      "type": "boolean"
    },
    "require_final_synthesis": {
      "type": "boolean"
    },
    "embedding_provider": {
      "enum": [
        "hash",
        "gemini-embedding-2"
      ],
      "default": "hash"
    },
    "embedding_dimension": {
      "type": "integer",
      "minimum": 8,
      "maximum": 3072,
      "default": 3072
    },
    "budget": {
      "type": "object",
      "required": [
        "max_iterations",
        "allocation_mass_per_iteration",
        "max_children_per_iteration",
        "max_relation_pairs_per_episode",
        "max_research_iterations"
      ],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "allocation_mass_per_iteration": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 3
        },
        "max_children_per_iteration": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 5
        },
        "max_relation_pairs_per_episode": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 3
        },
        "max_research_iterations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "min_iterations_before_synthesis": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 2
        },
        "entropy_change_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.05
        },
        "t_max": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "maximum": 10.0,
          "default": 1.0
        }
      }
    }
  }
}
