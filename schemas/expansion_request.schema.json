{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExpansionRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["parent", "count", "iteration"],
  "properties": {
    "parent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "node_type", "claim"],
      "properties": {
        "node_id": {"type": "string"},
        "node_type": {"enum": ["candidate", "evidence", "counterexample", "merge", "synthesis"]},
        "claim": {"type": "string", "minLength": 1},
        "rationale": {"type": "string"},
        "assumptions": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": "array", "items": {"type": "string"}},
        "risks": {"type": "array", "items": {"type": "string"}},
        "parent_ids": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "local_embedding": {"type": ["array", "null"], "items": {"type": "number"}},
        "judge_reasoning": {"type": ["string", "null"]},
        "score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "uncertainty": {"type": ["number", "null"], "minimum": 0},
        "ucb_score": {"type": ["number", "null"]},
        "expansion_budget": {"type": "integer", "minimum": 0},
        "status": {"enum": ["frontier", "closed", "archived", "merged", "synthesis"]}
      }
    },
    "count": {"type": "integer", "minimum": 0},
    "iteration": {"type": "integer", "minimum": 1},
    "spec": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["problem", "goal", "mode", "budget"],
      "properties": {
        "problem": {"type": "string", "minLength": 1},
        "goal": {"type": "string", "minLength": 1},
        "constraints": {"type": "array", "items": {"type": "string"}},
        "mode": {"const": "mandatory_frontier"},
        "allow_self_organized_executor": {"type": "boolean"},
        "require_final_synthesis": {"type": "boolean"},
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_iterations", "total_child_budget", "max_research_iterations"],
          "properties": {
            "max_iterations": {"type": "integer", "minimum": 1, "maximum": 20},
            "total_child_budget": {"type": "integer", "minimum": 1, "maximum": 50},
            "max_research_iterations": {"type": "integer", "minimum": 0, "maximum": 5}
          }
        }
      }
    }
  }
}
